#!/bin/sh
# qmanager_dpi_install — Download and install nfqws binary from zapret releases
# Spawned by CGI, writes progress to /tmp/qmanager_dpi_install.json
#
# Approach: Download the upstream zapret release tarball (openwrt-embedded),
# extract only the nfqws binary for the detected architecture, install to
# /usr/bin/nfqws, and verify it works. Skips the full zapret package to avoid
# opkg dependency issues on custom firmware.

. /usr/lib/qmanager/qlog.sh

qlog_init "dpi_install"

RESULT_FILE="/tmp/qmanager_dpi_install.json"
PID_FILE="/tmp/qmanager_dpi_install.pid"
INSTALL_DIR="/usr/bin"
NFQWS_BIN="$INSTALL_DIR/nfqws"
TMP_DIR="/tmp/qmanager_dpi_download"

# Optional mainland-friendly proxy wrapper (prefix). Set ZAPRET_USE_GHPROXY=0 to disable.
GHPROXY_PREFIX="${GHPROXY_PREFIX:-https://ghproxy.net/}"

_wrap_http_url() {
    _in="$1"
    case "${ZAPRET_USE_GHPROXY:-1}" in
        0|false|no|disabled|off) echo "$_in" ;;
        *) echo "${GHPROXY_PREFIX}${_in}" ;;
    esac
}

GITHUB_API=$(_wrap_http_url "https://api.github.com/repos/bol-van/zapret/releases/latest")

# Write PID for singleton check
echo $$ > "$PID_FILE"

cleanup() {
    rm -rf "$TMP_DIR"
    rm -f "$PID_FILE"
}
trap cleanup EXIT INT TERM

# Write status to result file
write_result() {
    local status="$1" message="$2" detail="$3"
    printf '{"success":%s,"status":"%s","message":"%s","detail":"%s"}' \
        "$([ "$status" = "complete" ] && echo 'true' || echo 'false')" \
        "$status" "$message" "$detail" > "$RESULT_FILE"
}

# Detect device architecture
detect_arch() {
    local machine
    machine=$(uname -m 2>/dev/null)
    case "$machine" in
        aarch64)   echo "linux-arm64" ;;
        armv7l)    echo "linux-arm" ;;
        x86_64)    echo "linux-x86_64" ;;
        mips)      echo "linux-mips" ;;
        mipsel)    echo "linux-mipsel" ;;
        *)
            qlog_error "Unsupported architecture: $machine"
            return 1
            ;;
    esac
}

# --- Main ---

qlog_info "Starting nfqws installation"
write_result "running" "Detecting architecture..." ""

# Step 1: Detect architecture
arch=$(detect_arch)
if [ -z "$arch" ]; then
    write_result "error" "Unsupported architecture" "$(uname -m)"
    exit 1
fi
qlog_info "Detected architecture: $arch"
write_result "running" "Architecture: $arch" "Fetching latest release..."

# Step 2: Get latest release tarball URL
# Look for the openwrt-embedded tarball (smaller, contains only binaries)
qlog_info "Querying GitHub API for latest zapret release"
release_json=$(curl -s -L -H "User-Agent: QManager" -w '\n%{http_code}' "$GITHUB_API" 2>/dev/null)

# Split response body from HTTP status code (last line)
http_code=$(echo "$release_json" | tail -1)
release_json=$(echo "$release_json" | sed '$d')

if [ -z "$release_json" ]; then
    write_result "error" "Failed to reach GitHub API" "Check internet connection"
    exit 1
fi

# Check for GitHub API errors (rate limiting, auth issues, etc.)
api_error=$(echo "$release_json" | jq -r '.message // empty' 2>/dev/null)
if [ -n "$api_error" ] && [ -z "$(echo "$release_json" | jq -r '.assets // empty' 2>/dev/null)" ]; then
    qlog_error "GitHub API error (HTTP $http_code): $api_error"
    write_result "error" "GitHub API error (HTTP $http_code)" "$api_error"
    exit 1
fi

release_tag=$(echo "$release_json" | jq -r '.tag_name // empty' 2>/dev/null)
qlog_info "Latest release: ${release_tag:-unknown} (HTTP $http_code)"

# List available assets for debugging
asset_names=$(echo "$release_json" | jq -r '.assets[].name' 2>/dev/null)
qlog_info "Release assets: $asset_names"

# Note: jq test() requires oniguruma regex which many OpenWRT jq builds lack.
# Use endswith()/contains() instead — they are built-in and always available.
tarball_url=$(echo "$release_json" | jq -r '.assets[] | select(.name | endswith("-openwrt-embedded.tar.gz")) | .browser_download_url' 2>/dev/null)

if [ -z "$tarball_url" ]; then
    # Fallback: try any .tar.gz asset (skip sha256sum.txt, .zip)
    tarball_url=$(echo "$release_json" | jq -r '.assets[] | select(.name | endswith(".tar.gz")) | .browser_download_url' 2>/dev/null | head -1)
fi

if [ -z "$tarball_url" ]; then
    asset_count=$(echo "$release_json" | jq '.assets | length' 2>/dev/null)
    qlog_error "No matching tarball in ${asset_count:-0} assets: $asset_names"
    write_result "error" "No compatible release found" "Release $release_tag has ${asset_count:-0} assets, none match expected pattern. Check /tmp/qmanager.log"
    exit 1
fi

qlog_info "Found release $release_tag: $tarball_url"
write_result "running" "Downloading zapret $release_tag..." ""

# Step 3: Download tarball
mkdir -p "$TMP_DIR"
tarball="$TMP_DIR/zapret.tar.gz"

if ! curl -s -L -H "User-Agent: QManager" -o "$tarball" "$(_wrap_http_url "$tarball_url")" 2>/dev/null; then
    write_result "error" "Download failed" "Could not download $tarball_url"
    exit 1
fi

# Verify download is not empty
if [ ! -s "$tarball" ]; then
    write_result "error" "Download failed" "Downloaded file is empty"
    exit 1
fi

qlog_info "Downloaded tarball ($(wc -c < "$tarball") bytes)"
write_result "running" "Extracting nfqws binary..." ""

# Step 4: Extract only the nfqws binary for our architecture
# The tarball structure is: zapret-vXX/binaries/<arch>/nfqws
nfqws_path=$(tar tzf "$tarball" 2>/dev/null | grep "binaries/$arch/nfqws$" | head -1)

if [ -z "$nfqws_path" ]; then
    write_result "error" "Binary not found in archive" "No nfqws for $arch in tarball"
    exit 1
fi

if ! tar xzf "$tarball" -C "$TMP_DIR" "$nfqws_path" 2>/dev/null; then
    write_result "error" "Extraction failed" "Could not extract $nfqws_path"
    exit 1
fi

extracted="$TMP_DIR/$nfqws_path"
if [ ! -f "$extracted" ]; then
    write_result "error" "Extraction failed" "File not found after extraction"
    exit 1
fi

qlog_info "Extracted nfqws binary ($(wc -c < "$extracted") bytes)"
write_result "running" "Installing nfqws..." ""

# Step 5: Install binary
cp "$extracted" "$NFQWS_BIN"
chmod 755 "$NFQWS_BIN"

# Step 6: Verify it runs
nfqws_version=$("$NFQWS_BIN" --version 2>&1 | head -1)
if [ -z "$nfqws_version" ]; then
    rm -f "$NFQWS_BIN"
    write_result "error" "Binary verification failed" "nfqws does not run on this device"
    exit 1
fi

qlog_info "nfqws installed successfully: $nfqws_version"
write_result "complete" "nfqws installed successfully" "$release_tag"

exit 0
