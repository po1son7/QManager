ev_loss_alerted=false

# Boot-only data (populated once)
boot_firmware=""
boot_build_date=""
boot_manufacturer=""
boot_model=""
boot_imei=""
boot_imsi=""
boot_iccid=""
boot_phone_number=""
boot_lte_category=""
boot_supported_lte_bands=""
boot_supported_nsa_nr5g_bands=""
boot_supported_sa_nr5g_bands=""
boot_qmanager_version=""
boot_ippt_mode="disabled"
boot_ippt_mac=""
