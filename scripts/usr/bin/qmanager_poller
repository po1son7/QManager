#!/bin/sh
# =============================================================================
# qmanager_poller â€” QManager Background Poller Daemon
# =============================================================================
# Continuously gathers modem data and system metrics, writes to the
# JSON state cache at /tmp/qmanager_status.json.
#
# Strategy: "Sip, Don't Gulp"
#   - Acquire lock â†’ run ONE AT command â†’ release â†’ sleep â†’ repeat
#   - Leaves gaps for terminal/watchdog to access the modem
#
# Tiers:
#   Tier 1 (Hot):    Every cycle (~2s)  â€” AT+QENG="servingcell", /proc reads,
#                                         AT+QRSRP, AT+QRSRQ, AT+QSINR (per-antenna signal)
#   Tier 1.5:        Every 5 cycles (10s) â€” watchcat state + ping history append
#   Tier 2 (Warm):   Every 15 cycles    â€” AT+QTEMP, AT+COPS?, AT+CPIN?, AT+QUIMSLOT?,
#                                         AT+QCAINFO, AT+QNWCFG="*_time_advance",
#                                         AT+QNWCFG="*_mimo_layers" (network-mode-gated),
#                                         AT+CGCONTRDP, AT+QMAP="WWAN"
#   Boot-only:     Once at startup    â€” AT+CVERSION, AT+CGSN, AT+CIMI, AT+QCCID,
#                                       AT+CNUM, AT+QGETCAPABILITY,
#                                       AT+QNWPREFCFG="policy_band"
#
# Libraries (sourced at startup):
#   /usr/lib/qmanager/qlog.sh      â€” Centralized logging
#   /usr/lib/qmanager/parse_at.sh  â€” AT command response parsers
#   /usr/lib/qmanager/events.sh    â€” Network event detection
#
# Install location: /usr/bin/qmanager_poller
# =============================================================================

# --- Configuration -----------------------------------------------------------
CACHE_FILE="/tmp/qmanager_status.json"
